            "significance": 0.3,
            "novelty": 0.2,
            "diversity": 0.1
        }
    },
    "llm": {
        "key_dir": ".",
        "max_tokens": 2048,
        "temperature": 0.7,
        "debate_rounds": 3,
        "consensus_min_providers": 2
